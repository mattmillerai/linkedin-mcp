# Copy to .env and fill in. See README "Prerequisites" for where these come from.

# Random string used to sign the OAuth session cookie on the local callback server.
SESSION_SECRET=change-me-to-a-long-random-string

# Port for the OAuth callback server (npm run dev:auth).
AUTH_PORT=8000

# Port for the MCP server's HTTP/SSE transport. Must differ from AUTH_PORT.
HTTP_PORT=8001

# From your LinkedIn Developer App (https://www.linkedin.com/developers/apps).
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret

# Must EXACTLY match an Authorized Redirect URL configured on the LinkedIn app.
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback
